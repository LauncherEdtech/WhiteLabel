cat > /workspaces/WhiteLabel/.gitignore << 'EOF'
# ── Python ──────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── Ambiente virtual ────────────────────
venv/
env/
.venv/
.env/

# ── Node.js ─────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Next.js ─────────────────────────────
frontend/.next/
frontend/out/
frontend/.turbo/

# ── Variáveis de ambiente ───────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
api/.env
frontend/.env.local

# ── Terraform ───────────────────────────
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/*.tfvars
!infra/environments/staging.tfvars
infra/environments/production.tfvars

# ── Docker ──────────────────────────────
.docker/

# ── IDEs ────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────
*.log
logs/

# ── Arquivos temporários ─────────────────
*.tmp
*.temp
/tmp/

# ── Arquivos acidentais ──────────────────
"ecs list-tasks \\"
EOF

echo "✓ .gitignore criado"
# ── Terraform providers (binários grandes) ──────────────────
infra/.terraform/
infra/.terraform.lock.hcl

# ── AWS CLI installer ───────────────────────────────────────
awscliv2.zip
aws/

# ── TypeScript build cache ──────────────────────────────────
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# ── Arquivos acidentais ─────────────────────────────────────
"ecs list-tasks \\"

# .env.example
# Copie para .env e preencha os valores. NUNCA commite o .env real no Git.

# ── Banco de Dados ──────────────────────────────────────────────────────────
POSTGRES_USER=concurso_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=concurso_platform

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── Flask ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
# SEGURANÇA: Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GERE_UMA_CHAVE_DE_256_BITS
JWT_SECRET_KEY=GERE_OUTRA_CHAVE_DIFERENTE

# ── IA ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── Celery Monitor ──────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── E-mail (SES na AWS) ─────────────────────────────────────────────────────
MAIL_SERVER=smtp.ses.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@seudominio.com

# ── Storage S3 ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
// .devcontainer/devcontainer.json
{
  "name": "Concurso Platform API",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "api",
  "workspaceFolder": "/workspace",

  // Extensões recomendadas para o VS Code / Codespaces
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.flake8",
        "ms-python.black-formatter",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "humao.rest-client",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  },

  // Portas expostas para desenvolvimento
  "forwardPorts": [5000, 5432, 6379, 5555],
  "portsAttributes": {
    "5000": { "label": "Flask API" },
    "5432": { "label": "PostgreSQL" },
    "6379": { "label": "Redis" },
    "5555": { "label": "Flower (Celery Monitor)" }
  },

  // Comando executado após o container subir
  "postCreateCommand": "cd api && pip install -r requirements.txt && cp ../.env.example ../.env"
}